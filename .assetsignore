# Files that must NOT be uploaded/served as public static assets.
# gitignore-style syntax. Fixes the "Asset too large" (node_modules/workerd) error
# and keeps backend source / secrets / docs off the public site.

node_modules
.git
.gitignore
.assetsignore
worker.js
wrangler.toml
wrangler.jsonc
package.json
package-lock.json
bun.lockb

# Secrets
.env
.env.*

# Backend source and tooling (logic is bundled into worker.js, not served raw)
server
api
netlify
functions
docs
.gstack
.tmp_ref
*.md
